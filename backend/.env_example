# backend/.env 로 복사한 뒤 값을 채우세요. (cp .env_example .env)
# 배포 서버에서는 호스트 환경 변수나 시크릿 관리에 동일한 키 이름으로 주입하면 됩니다.

# --- 필수 (DB·인증) ---
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
JWT_SECRET_KEY=랜덤_긴_문자열_운영에서는_반드시_교체

# --- 배포 시 프론트 도메인 (쉼표로 여러 개) ---
# 로컬 Vite 기본 origin 은 코드에 포함되어 있음. 프로덕션 URL 만 추가하면 됩니다.
# 예: CORS_ORIGINS=https://your-app.example.com,https://www.your-app.example.com
CORS_ORIGINS=

# --- 선택: MongoDB (코드에 클라이언트가 있을 때) ---
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=capstone_db

# --- AI API (사용하는 경로만 채우면 됨) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

HF_TOKEN=
HF_BASE_URL=https://router.huggingface.co/v1
HF_CHAT_MODEL=
HF_MODEL=facebook/bart-large-mnli
